# Copy to .env and fill only what you need.

# Teacher trajectory collection
OPENAI_API_KEY=
OPENAI_TEACHER_MODEL=gpt-4.1-2025-04-14

# Optional judge model for DMR accuracy labels
OPENAI_JUDGE_MODEL=gpt-4.1-2025-04-14

# Local student model
STUDENT_MODEL_ID=meta-llama/Meta-Llama-3-8B-Instruct
STUDENT_CONTEXT_WINDOW=8192
STUDENT_TOKENIZER_MODE=auto
STUDENT_TOOL_CALL_PARSER=llama3_json
HF_TOKEN=
HF_HOME=/root/.cache/huggingface

# vLLM is exposed on host port 8001 to avoid colliding with the shared AI_dev server.
VLLM_HOST_BASE_URL=http://localhost:8001/v1
VLLM_API_KEY=EMPTY

# Letta / MemGPT services
LETTA_BASE_URL=http://letta-server:8283
LETTA_API_KEY=EMPTY
LETTA_PG_URI=postgresql://nanomemgpt:nanomemgpt@pgvector:5432/nanomemgpt

# PostgreSQL + pgvector archival/recall storage
POSTGRES_HOST=pgvector
POSTGRES_PORT=5432
POSTGRES_DB=nanomemgpt
POSTGRES_USER=nanomemgpt
POSTGRES_PASSWORD=nanomemgpt

# Logging
WANDB_PROJECT=nano-memgpt
WANDB_MODE=offline
